# Quad AS nettsted — miljøvariabler (sett disse i Render → Environment)

# Offentlig adresse (brukes i e-post)
PUBLIC_URL=https://www.quad.no

# SMTP — samme som sabi-apartment (sjekk verdiene i Render på den tjenesten)
SMTP_HOST=smtp.domeneshop.no
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=din-smtp-bruker
SMTP_PASS=ditt-smtp-passord

# E-post
MAIL_FROM=Quad AS <invest@quad.no>
MAIL_TO=invest@quad.no
